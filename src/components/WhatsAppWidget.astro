---
import { contact } from '../data/site';
const waNumber = contact.phone.replace(/[^0-9]/g, '');
const waText = encodeURIComponent('Halo AESI, saya ingin bertanya tentang keanggotaan.');
---

<a
  href={`https://wa.me/${waNumber}?text=${waText}`}
  target="_blank"
  rel="noopener"
  data-wa-widget
  data-show-at="400"
  class="wa-widget opacity-0 pointer-events-none"
  aria-label="Hubungi kami via WhatsApp"
>
  <span class="i-carbon-logo-whatsapp text-3xl" aria-hidden="true"></span>
  <span class="wa-pulse" aria-hidden="true"></span>
</a>
