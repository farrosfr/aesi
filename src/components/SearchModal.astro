---
/**
 * Search modal: fullscreen overlay with input + filtered results.
 * Triggered by [data-search-trigger] buttons (e.g. in Header).
 * Closed by clicking backdrop, ESC key, or [data-search-close].
 * Loads /search-index.json (built from src/data/search-index.ts).
 */
---

<div
  data-search-modal
  class="search-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="Pencarian"
  hidden
>
  <button data-search-backdrop class="search-backdrop" aria-label="Tutup pencarian" type="button"></button>
  <div data-search-panel class="search-panel" role="document">
    <div class="search-input-wrap">
      <span class="i-carbon-search text-2xl text-ink-muted" aria-hidden="true"></span>
      <input
        data-search-input
        type="search"
        placeholder="Cari artikel, halaman, program..."
        autocomplete="off"
        aria-label="Cari"
        class="flex-1 bg-transparent border-0 outline-none text-base py-2 text-ink placeholder-ink-subtle"
      />
      <kbd class="search-kbd">ESC</kbd>
    </div>
    <div id="search-results" class="search-results" aria-live="polite">
      <p class="search-hint">Ketik untuk mencari...</p>
    </div>
    <div class="search-footer">
      <span><kbd class="search-kbd">&uarr;</kbd> <kbd class="search-kbd">&darr;</kbd> navigasi</span>
      <span><kbd class="search-kbd">&crarr;</kbd> buka</span>
      <span><kbd class="search-kbd">ESC</kbd> tutup</span>
    </div>
    <button data-search-close class="search-close" aria-label="Tutup" type="button">
      <span class="i-carbon-close text-xl" aria-hidden="true"></span>
    </button>
  </div>
</div>
