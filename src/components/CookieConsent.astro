---
/**
 * Cookie consent banner: shown on first visit (localStorage check),
 * dismissable. Saves preference to localStorage.
 * The JS expects: data-cookie-consent on outer, data-cookie-accept and
 * data-cookie-reject on buttons. The inner panel is the slide-up element.
 */
---

<div
  data-cookie-consent
  class="cookie-banner-wrap"
  role="dialog"
  aria-label="Pemberitahuan cookies"
>
  <div class="cookie-banner-inner translate-y-full opacity-0 transition-all duration-500">
    <div class="cookie-content">
      <div class="cookie-icon shrink-0">
        <span class="i-carbon-cookie text-2xl text-primary" aria-hidden="true"></span>
      </div>
      <p class="cookie-text">
        Kami menggunakan cookies untuk meningkatkan pengalaman Anda di situs ini. Dengan melanjutkan, Anda menyetujui penggunaan cookies sesuai kebijakan privasi kami.
      </p>
      <div class="cookie-actions">
        <button data-cookie-reject type="button" class="cookie-btn-secondary">
          Tolak
        </button>
        <button data-cookie-accept type="button" class="cookie-btn-primary">
          Saya Setuju
        </button>
      </div>
    </div>
  </div>
</div>
