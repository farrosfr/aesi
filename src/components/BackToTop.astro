---
/**
 * Back-to-top button, fixed bottom-right (above WhatsApp widget on mobile,
 * right side on desktop at sm+). Shows after 400px scroll.
 */
---

<button
  type="button"
  data-back-to-top
  aria-label="Kembali ke atas"
  class="fixed bottom-6 right-6 sm:right-24 z-40 w-12 h-12 rounded-full bg-ink/90 text-white shadow-lg hover:bg-ink hover:scale-105 transition-all opacity-0 pointer-events-none"
>
  <span class="i-carbon-arrow-up text-xl block" aria-hidden="true"></span>
</button>
