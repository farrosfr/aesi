---
/**
 * Back to top button: floating, scroll-revealed after 400px.
 * Positioned above the WhatsApp widget.
 * The JS uses [data-back-to-top] selector and toggles opacity classes.
 */
---

<button
  data-back-to-top
  data-floating
  type="button"
  class="back-to-top opacity-0 pointer-events-none"
  aria-label="Kembali ke atas"
>
  <span class="i-carbon-arrow-up text-xl" aria-hidden="true"></span>
</button>
