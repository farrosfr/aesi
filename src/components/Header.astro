---
import { navigation, site } from '../data/site';

const { transparent = false } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = (href?: string) =>
  href === pathname || (Boolean(href) && href !== '/' && pathname.startsWith(href));
---

<header
  id="main-header"
  class:list={[
    'sticky top-0 z-40 w-full transition-colors duration-300',
    transparent && 'transparent',
  ]}
  data-transparent={transparent ? 'true' : 'false'}
>
  {/* ROW 1: utility bar */}
  <div class="hidden lg:block border-b border-white/10">
    <div class="container-wide flex items-center justify-end gap-5 py-2 text-xs">
      <a href="/kontak/" class="utility-text link-underline">Hubungi Kami</a>
      <span class="utility-text opacity-30">|</span>

      <div class="relative" data-lang-switcher>
        <button
          type="button"
          aria-label="Ganti bahasa"
          data-lang-trigger
          aria-haspopup="listbox"
          aria-expanded="false"
          class="utility-text bg-transparent border-0 cursor-pointer flex items-center gap-1.5 p-0 text-xs"
        >
          <span class="i-carbon-language text-sm" aria-hidden="true"></span>
          <span data-current-lang>ID</span>
          <span class="i-carbon-chevron-down text-xs opacity-70" aria-hidden="true"></span>
        </button>
        <ul
          data-lang-menu
          class="lang-menu absolute right-0 top-full mt-1 min-w-[5rem] bg-white border border-gray-200 rounded-md shadow-lg py-1 z-50"
          role="listbox"
        >
          <li>
            <button type="button" data-lang="id" data-lang-option class="block w-full text-left px-3 py-1.5 text-xs text-ink hover:bg-surface font-bold">
              ID
            </button>
          </li>
          <li>
            <button type="button" data-lang="en" data-lang-option class="block w-full text-left px-3 py-1.5 text-xs text-ink hover:bg-surface">
              EN
            </button>
          </li>
        </ul>
      </div>

      <span class="utility-text opacity-30">|</span>
      <a href="/anggota/#gabung" class="utility-text link-underline">Registrasi Anggota</a>

      <button
        type="button"
        aria-label="Buka pencarian"
        data-search-trigger
        class="utility-text bg-transparent border-0 cursor-pointer p-1"
      >
        <span class="i-carbon-search text-base" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  {/* ROW 2: main nav */}
  <div class="container-wide flex items-center justify-between h-16 lg:h-20">
    <a href="/" class="flex items-center gap-3 shrink-0">
      {/*
        Note: we deliberately do NOT render a second logo with
        class="logo-white" here. The previous build had one but the only
        white logo asset (public/uploads/static/AESI_Logo_White.png) is
        actually a 1920x1080 hero banner (not a small icon) that someone
        accidentally uploaded with the wrong filename. At the rendered
        size of h-12 (48px) it became an 85x48 mostly-white rectangle that
        looked like "empty white space" on the left of the header. The
        CSS rule below inverts the color logo when the header sits over
        a dark hero, so we get a white-look logo without needing a
        separate white asset.
      */}
      <img
        src="/uploads/static/Logo-AESI-1-1.png"
        alt={site.name}
        class="logo-color h-10 lg:h-12 w-auto"
        width="297"
        height="141"
      />
      <span class="hidden sm:inline-block font-heading font-bold text-base lg:text-lg leading-tight">
        {site.name}
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Menu utama">
      {navigation.map((item) => (
        <div class="relative" data-dropdown={item.children ? 'true' : undefined}>
          {item.children ? (
            <>
              <button
                data-dropdown-trigger
                class:list={[
                  'appearance-none bg-transparent border-0 cursor-pointer nav-link px-3 py-2 text-sm font-medium transition-colors flex items-center gap-1',
                  item.children?.some(c => isActive(c.href)) ? 'active' : '',
                ]}
                aria-expanded="false"
                type="button"
              >
                {item.label}
                <span class="i-carbon-chevron-down text-xs chev" aria-hidden="true"></span>
              </button>
              <div
                data-dropdown-menu
                class="absolute top-full left-0 min-w-[16rem] bg-white border border-gray-200 rounded-md shadow-lg py-2 z-50"
              >
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block px-4 py-2 text-sm hover:bg-gray-50',
                      isActive(child.href) ? 'text-primary font-medium' : 'text-ink',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class:list={[
                'nav-link block px-3 py-2 text-sm font-medium transition-colors',
                isActive(item.href) ? 'active' : '',
              ]}
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
    </nav>

    <a
      href="/anggota/#gabung"
      class="hidden lg:inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-primary text-white font-semibold text-sm hover:bg-primary-dark hover:gap-3 transition-all"
    >
      Gabung
    </a>

    <button
      type="button"
      data-menu-toggle
      class="lg:hidden p-2 rounded-md hover:bg-white/10"
      aria-label="Buka menu"
      aria-expanded="false"
    >
      <span class="i-carbon-menu block text-2xl" aria-hidden="true"></span>
    </button>
  </div>

  <div data-mobile-menu class="hidden lg:hidden border-t border-gray-200">
    <nav class="container-wide py-4 flex flex-col gap-1" aria-label="Menu seluler">
      {navigation.map((item) => (
        <div class="border-b border-gray-100 last:border-b-0 py-2">
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 font-medium',
              isActive(item.href) ? 'text-primary' : 'text-ink',
            ]}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="ml-4 mt-1 flex flex-col gap-1 border-l-2 border-gray-100 pl-3">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block py-1 text-sm',
                    isActive(child.href) ? 'text-primary font-medium' : 'text-ink-muted',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <button
        type="button"
        data-search-trigger
        class="mt-4 w-full inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full border border-ink-muted/20 text-ink font-semibold text-sm hover:bg-surface transition-colors"
      >
        <span class="i-carbon-search" aria-hidden="true"></span>
        Cari di situs
      </button>
      <a
        href="/anggota/#gabung"
        class="mt-2 inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-primary text-white font-semibold text-sm hover:bg-primary-dark transition-colors"
      >
        Gabung Sekarang
      </a>
    </nav>
  </div>
</header>

<style>
  #main-header {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid #e5e7eb;
    color: #1a1a1a;
  }
  #main-header.transparent {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid transparent;
    color: #ffffff;
  }
  #main-header.scrolled {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid #e5e7eb;
    color: #1a1a1a;
  }
  #main-header .logo-color { display: block; }
  #main-header .nav-link { color: inherit; }
  #main-header .nav-link:hover { color: #00992e; }
  #main-header:not(.transparent) .nav-link.active { color: var(--color-primary); font-weight: 600; }
  #main-header.transparent:not(.scrolled) .nav-link:hover { color: #ffffff; opacity: 0.85; }
  #main-header.transparent:not(.scrolled) .nav-link.active { color: #ffffff; opacity: 1; font-weight: 600; }
  #main-header .utility-text { color: inherit; }
  #main-header.transparent:not(.scrolled) .utility-text { color: #ffffff; opacity: 0.9; }
  [data-mobile-menu] { background: white; color: #1a1a1a; }
  .chev { transition: transform 0.2s; display: inline-block; }
  [data-dropdown-trigger][aria-expanded="true"] .chev { transform: rotate(180deg); }
  [data-dropdown-menu] {
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
  }
  [data-dropdown]:hover [data-dropdown-menu],
  [data-dropdown-trigger][aria-expanded="true"] + [data-dropdown-menu] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>
