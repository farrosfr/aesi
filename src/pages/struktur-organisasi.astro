---
import Base from '../layouts/Base.astro';
---

<Base title="Struktur Organisasi">
  <section class="bg-surface-muted section">
    <div class="container-narrow">
      <p class="eyebrow mb-3">Tentang Kami</p>
      <h1 class="heading-2 mb-6">Struktur Organisasi</h1>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-narrow">
      <p class="text-lg text-ink-muted mb-12">
        AESI dijalankan oleh tim pengurus yang dipilih melalui mekanisme organisasi, didukung oleh tiga Wakil Ketua Umum yang menaungi bidang kebijakan, riset, dan kerja sama.
      </p>

      <div class="space-y-6">
        <div class="bg-surface-muted rounded-lg p-6">
          <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-2">Puncak</p>
          <h3 class="heading-3 mb-1">Ketua Umum</h3>
          <p class="text-sm text-ink-muted">Memimpin organisasi secara keseluruhan.</p>
        </div>

        <div class="grid sm:grid-cols-3 gap-4">
          <a href="/program/wku-1/" class="bg-surface-muted rounded-lg p-6 hover:bg-primary hover:text-white transition-colors group">
            <p class="text-xs uppercase tracking-widest text-primary group-hover:text-white font-semibold mb-2">WKU 1</p>
            <h3 class="font-semibold text-lg mb-1">Kebijakan &amp; Regulasi</h3>
            <p class="text-sm text-ink-muted group-hover:text-white/80">Pemetaan regulasi dan advokasi kebijakan.</p>
          </a>

          <a href="/program/wku-2/" class="bg-surface-muted rounded-lg p-6 hover:bg-primary hover:text-white transition-colors group">
            <p class="text-xs uppercase tracking-widest text-primary group-hover:text-white font-semibold mb-2">WKU 2</p>
            <h3 class="font-semibold text-lg mb-1">Riset &amp; Teknologi</h3>
            <p class="text-sm text-ink-muted group-hover:text-white/80">Pengembangan riset dan teknologi PLTS.</p>
          </a>

          <a href="/program/wku-3/" class="bg-surface-muted rounded-lg p-6 hover:bg-primary hover:text-white transition-colors group">
            <p class="text-xs uppercase tracking-widest text-primary group-hover:text-white font-semibold mb-2">WKU 3</p>
            <h3 class="font-semibold text-lg mb-1">Kerja Sama</h3>
            <p class="text-sm text-ink-muted group-hover:text-white/80">Kemitraan strategis lintas sektor.</p>
          </a>
        </div>

        <div class="bg-surface-muted rounded-lg p-6">
          <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-2">Pendukung</p>
          <h3 class="heading-3 mb-1">Sekretariat</h3>
          <p class="text-sm text-ink-muted">Mengelola operasional harian organisasi dan hubungan anggota.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
