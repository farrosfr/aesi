---
import Base from '../layouts/Base.astro';
---

<Base title="Halaman Tidak Ditemukan">
  <section class="section bg-white min-h-[60vh] flex items-center">
    <div class="container-narrow text-center">
      <p class="text-9xl font-bold text-primary opacity-30">404</p>
      <h1 class="heading-2 mt-4 mb-3">Halaman Tidak Ditemukan</h1>
      <p class="text-ink-muted mb-8 text-lg">
        Maaf, halaman yang Anda cari tidak tersedia atau telah dipindahkan.
      </p>
      <a href="/" class="btn-primary">
        <span class="i-carbon-home" aria-hidden="true"></span>
        Kembali ke Beranda
      </a>
    </div>
  </section>
</Base>
