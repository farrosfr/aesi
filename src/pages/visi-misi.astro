---
import Base from '../layouts/Base.astro';
---

<Base title="Visi & Misi">
  <section class="bg-surface-muted section">
    <div class="container-narrow">
      <p class="eyebrow mb-3">Tentang Kami</p>
      <h1 class="heading-2 mb-6">Visi &amp; Misi</h1>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-narrow">
      <div class="bg-gradient-to-br from-primary to-primary-dark text-white rounded-2xl p-8 lg:p-12 mb-12">
        <p class="text-sm uppercase tracking-widest text-white/70 mb-3">Visi</p>
        <p class="text-2xl lg:text-3xl font-bold leading-snug">
          Menjadi asosiasi energi surya terkemuka di Indonesia yang mendorong transisi energi bersih dan berkelanjutan.
        </p>
      </div>

      <h2 class="heading-3 mb-6">Misi</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="i-carbon-chat text-2xl text-primary" aria-hidden="true"></span>
          </div>
          <div>
            <h3 class="font-semibold text-lg mb-1">Forum Komunikasi</h3>
            <p class="text-ink-muted">Menjadi wadah komunikasi dan dialog antar pemangku kepentingan energi surya Indonesia.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="i-carbon-document text-2xl text-primary" aria-hidden="true"></span>
          </div>
          <div>
            <h3 class="font-semibold text-lg mb-1">Kebijakan &amp; Regulasi</h3>
            <p class="text-ink-muted">Mendorong terbentuknya kebijakan dan regulasi yang mendukung pengembangan energi surya.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="i-carbon-research text-2xl text-primary" aria-hidden="true"></span>
          </div>
          <div>
            <h3 class="font-semibold text-lg mb-1">Riset &amp; Teknologi</h3>
            <p class="text-ink-muted">Mengembangkan riset dan teknologi PLTS yang relevan dengan kebutuhan Indonesia.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="i-carbon-connect text-2xl text-primary" aria-hidden="true"></span>
          </div>
          <div>
            <h3 class="font-semibold text-lg mb-1">Kerja Sama Lintas Sektor</h3>
            <p class="text-ink-muted>Membangun kemitraan strategis antara pemerintah, swasta, akademisi, dan komunitas.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="i-carbon-education text-2xl text-primary" aria-hidden="true"></span>
          </div>
          <div>
            <h3 class="font-semibold text-lg mb-1">Pengembangan SDM</h3>
            <p class="text-ink-muted">Meningkatkan kapasitas sumber daya manusia di bidang energi surya melalui pelatihan dan sertifikasi.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
